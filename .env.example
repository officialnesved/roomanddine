# Where "Login"/"Start Free Trial"/"Book a Demo" success redirects point to. Defaults to
# https://app.roomanddine.com if unset — only needed locally to point at a dev instance.
VITE_APP_URL=http://localhost:5173

# Get a free access key at https://web3forms.com (just enter an email, no account/password).
# Submissions from the Contact form and Book a Demo modal are emailed to that address.
VITE_WEB3FORMS_KEY=
